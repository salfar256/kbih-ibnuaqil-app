rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Aturan keamanan KBIH Ibnu Aqil
    //
    // Data ini berisi informasi pribadi dan kesehatan jamaah.
    // Pembatasan di aplikasi saja tidak cukup — aturan di bawah
    // inilah yang benar-benar menegakkannya di sisi server.
    // ============================================================

    function login() { return request.auth != null; }

    function acuanAkun() {
      return /databases/$(database)/documents/akun/$(request.auth.uid);
    }
    function punyaCatatan() { return login() && exists(acuanAkun()); }
    function dataAkun()     { return get(acuanAkun()).data; }

    // Akun tanpa catatan dianggap sah — supaya akun lama tetap berfungsi.
    // Akun yang dinonaktifkan lewat halaman Pengaturan tertolak di sini.
    function aktif() { return login() && (!punyaCatatan() || dataAkun().aktif == true); }

    // Pembimbing: akses penuh. Jamaah: terbatas.
    function pembimbing() {
      return aktif() && (!punyaCatatan() || dataAkun().peran != 'Jamaah');
    }

    // Benar hanya bila jamaah membuka dokumen miliknya sendiri
    function jamaahIni(idJamaah) {
      return aktif() && punyaCatatan() && dataAkun().jamaahId == idJamaah;
    }

    // --- Data per periode haji/umroh ---
    match /periode/{idPeriode} {
      allow read:  if aktif();
      allow write: if pembimbing();

      // Data lengkap jamaah: pembimbing, atau jamaah itu sendiri
      match /jamaah/{idJamaah} {
        allow read, write: if pembimbing() || jamaahIni(idJamaah);
      }

      // Daftar ringkas (nama, foto, telepon) — boleh dilihat semua jamaah.
      // Tidak berisi data kesehatan maupun catatan harian.
      match /direktori/{idJamaah} {
        allow read:  if aktif();
        allow write: if pembimbing();
      }

      // Jadwal kegiatan boleh dilihat jamaah
      match /agenda/{idIsi} {
        allow read:  if aktif();
        allow write: if pembimbing();
      }

      // Riwayat laporan: jamaah boleh menambah catatannya sendiri,
      // tetapi tidak boleh membaca atau mengubah laporan pembimbing.
      match /laporan/{idIsi} {
        allow read:           if pembimbing();
        allow create:         if aktif();
        allow update, delete: if pembimbing();
      }

      // Kursi, absensi, dan titik lokasi: pembimbing saja
      match /{koleksi}/{idIsi} {
        allow read, write: if pembimbing();
      }
    }

    // --- Data bersama semua periode ---
    match /doa/{id}  { allow read: if aktif(); allow write: if pembimbing(); }
    match /fiqh/{id} { allow read: if aktif(); allow write: if pembimbing(); }

    // kategoriDoa, kategoriFiqh, telegram, darurat
    match /data/{id} { allow read: if aktif(); allow write: if pembimbing(); }

    // --- Daftar akun ---
    match /akun/{id} {
      allow read:  if login() && (request.auth.uid == id || pembimbing());
      allow write: if pembimbing();
    }

    // Selain yang disebut di atas: ditolak
    match /{document=**} { allow read, write: if false; }
  }
}
