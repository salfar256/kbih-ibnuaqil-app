rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hanya pembimbing yang sudah login yang boleh membaca & menulis.
    // Data ini berisi informasi pribadi dan kesehatan jamaah,
    // jadi jangan longgarkan aturan di bawah ini.

    function sudahLogin() {
      return request.auth != null;
    }

    // --- Data per periode haji/umroh ---
    // periode/{id}                      → keterangan periode
    // periode/{id}/jamaah/{id}          → data jamaah
    // periode/{id}/agenda/{id}          → jadwal kegiatan
    // periode/{id}/laporan/{id}         → riwayat laporan
    // periode/{id}/titikKumpul/{id}     → titik kumpul
    // periode/{id}/titikPenting/{id}    → lokasi penting
    // periode/{id}/tersesat/{id}        → jamaah tersesat
    // periode/{id}/data/{kursi|absensi} → denah kursi & absensi
    match /periode/{idPeriode} {
      allow read, write: if sudahLogin();
      match /{koleksi}/{idIsi} {
        allow read, write: if sudahLogin();
      }
    }

    // --- Data bersama semua periode ---
    match /doa/{id}   { allow read, write: if sudahLogin(); }
    match /fiqh/{id}  { allow read, write: if sudahLogin(); }

    // data/kategoriDoa, data/kategoriFiqh, data/telegram
    match /data/{id}  { allow read, write: if sudahLogin(); }

    // Selain yang disebut di atas: ditolak
    match /{document=**} { allow read, write: if false; }
  }
}
